{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "name": {
      "minLength": 1,
      "description": "The name of the skill.",
      "type": "string"
    },
    "bridge": {
      "description": "Bridge SDK.",
      "anyOf": [
        {
          "const": "python",
          "type": "string"
        },
        {
          "const": "nodejs",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "version": {
      "minLength": 1,
      "description": "Version following semver.",
      "type": "string"
    },
    "description": {
      "minLength": 1,
      "description": "This helps people understand what your skill does.",
      "type": "string"
    },
    "author": {
      "additionalProperties": false,
      "description": "A person who has been involved in creating or maintaining this skill.",
      "type": "object",
      "properties": {
        "name": {
          "minLength": 1,
          "description": "Name of the author.",
          "type": "string"
        },
        "email": {
          "minLength": 1,
          "maxLength": 254,
          "format": "email",
          "description": "Email address of the author.",
          "type": "string"
        },
        "url": {
          "minLength": 1,
          "maxLength": 255,
          "format": "uri",
          "description": "Website of the author.",
          "type": "string"
        }
      },
      "required": [
        "name"
      ]
    }
  },
  "required": [
    "name",
    "bridge",
    "version",
    "description",
    "author"
  ]
}